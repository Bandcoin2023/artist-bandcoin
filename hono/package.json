{
  "name": "bandcoin-hono-server",
  "type": "module",
  "scripts": {
    "build": "esbuild --bundle --outfile=./dist/index.js --platform=node --target=node20 ./src/index.ts",
    "deploy": "run-s build zip update",
    "sst:dev": "sst dev --stage ih",
    "sst:deploy": "sst deploy --stage ih",
    "sst:secrets:sync": "node scripts/sync-secrets.js ih",
    "sst:secrets:list": "pnpm dlx sst secret list --stage ih",
    "update": "aws lambda update-function-code --zip-file fileb://lambda.zip --function-name hello",
    "zip": "zip -j lambda.zip dist/index.js"
  },
  "devDependencies": {
    "@types/aws-lambda": "8.10.159",
    "esbuild": "^0.21.4",
    "npm-run-all2": "^6.2.0"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.946.0",
    "@aws-sdk/client-s3": "^3.948.0",
    "@aws-sdk/lib-dynamodb": "^3.946.0",
    "@google/genai": "^1.31.0",
    "@hono/swagger-ui": "^0.5.2",
    "@hono/zod-openapi": "^1.1.5",
    "hono": "^4.10.7",
    "openai": "^6.10.0",
    "sst": "3.17.25",
    "zod": "^4.1.13"
  }
}